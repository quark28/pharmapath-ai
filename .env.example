# PharmaPath AI — Environment Variables

PHARMA_DATA_DIR=./data/output
PHARMA_MODEL_DIR=./models
PHARMA_DEBUG=true

# LLM Backend: mock | ollama | openai
PHARMA_LLM_BACKEND=mock

# Ollama (local LLM)
PHARMA_OLLAMA_URL=http://localhost:11434
PHARMA_OLLAMA_MODEL=llama3

# OpenAI (cloud LLM, optional)
PHARMA_OPENAI_API_KEY=
PHARMA_OPENAI_MODEL=gpt-4o-mini

# Optimizer
PHARMA_MAX_VISITS_PER_DAY=14
PHARMA_SOLVER_TIME_LIMIT_SEC=5
PHARMA_AVG_SPEED_KMH=18.0